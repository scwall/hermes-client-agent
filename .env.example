# Hermes Agent configuration
# Copy this file to .env and adjust values

# Authentication token for API endpoints (change this!)
HERMES_AGENT_TOKEN=hermes-windows-agent-secret-change-me

# Optional: separate token for dashboard access (falls back to HERMES_AGENT_TOKEN if not set)
# HERMES_DASHBOARD_TOKEN=

# Host/interface to bind to (0.0.0.0 = all interfaces, 127.0.0.1 = local only)
HERMES_AGENT_HOST=0.0.0.0

# Port the agent listens on
HERMES_AGENT_PORT=8765

# Allowed file paths (os.pathsep separated)
# Defaults to user home and D:\
HERMES_ALLOWED_PATHS=

# Audit log retention
# Max rows in audit database (default: 100000)
# HERMES_AUDIT_MAX_ROWS=100000
# Max age of audit entries in days (default: 90)
# HERMES_AUDIT_MAX_AGE_DAYS=90
# Automatic cleanup after each log entry (default: true)
# HERMES_AUDIT_AUTO_CLEANUP=true
